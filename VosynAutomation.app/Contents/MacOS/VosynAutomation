#!/bin/bash
#
# VosynAutomation.app launcher
# Double-click app -> run setup if needed -> start app
#

APP_MACOS_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$APP_MACOS_DIR/../../.." && pwd)"

SETUP_SCRIPT="$PROJECT_ROOT/launcher/mac/setup.sh"
START_SCRIPT="$PROJECT_ROOT/launcher/mac/start.sh"

BACKEND_ENV="$PROJECT_ROOT/vosyn-automation/env/bin/python"
FRONTEND_NODE_MODULES="$PROJECT_ROOT/university-job-portal/university-job-portal/node_modules"

PROJECT_ROOT_ESCAPED="$(printf "%q" "$PROJECT_ROOT")"

if [ ! -f "$SETUP_SCRIPT" ]; then
  osascript -e 'display dialog "Could not find launcher/mac/setup.sh. Make sure VosynAutomation.app is inside the project root folder." buttons {"OK"} with icon stop'
  exit 1
fi

if [ ! -f "$START_SCRIPT" ]; then
  osascript -e 'display dialog "Could not find launcher/mac/start.sh. Make sure VosynAutomation.app is inside the project root folder." buttons {"OK"} with icon stop'
  exit 1
fi

chmod +x "$PROJECT_ROOT/launcher/mac/"*.sh 2>/dev/null

SETUP_REQUIRED=0

if [ ! -x "$BACKEND_ENV" ]; then
  SETUP_REQUIRED=1
fi

if [ ! -d "$FRONTEND_NODE_MODULES" ]; then
  SETUP_REQUIRED=1
fi

if [ "$SETUP_REQUIRED" -eq 1 ]; then
  osascript <<EOF
tell application "Terminal"
  activate
  do script "cd $PROJECT_ROOT_ESCAPED && clear && echo '========================================' && echo 'Vosyn Automation - First Time Setup' && echo '========================================' && echo '' && echo 'This may take several minutes on first run.' && echo 'Please keep this Terminal window open.' && echo '' && ./launcher/mac/setup.sh && echo '' && echo 'Setup complete. Starting Vosyn Automation...' && ./launcher/mac/start.sh"
end tell
EOF
else
  osascript <<EOF
tell application "Terminal"
  activate
  do script "cd $PROJECT_ROOT_ESCAPED && clear && ./launcher/mac/start.sh"
end tell
EOF
fi